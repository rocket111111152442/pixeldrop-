# ─────────────────────────────────────────────
#  PixelDrop — variables d'environnement
#  Copie ce fichier en .env et remplis les valeurs.
# ─────────────────────────────────────────────

# Base de données PostgreSQL (Neon / Supabase / Vercel Postgres / local)
DATABASE_URL="postgresql://user:password@localhost:5432/pixeldrop?schema=public"

# ── Auth.js ──
# Génère un secret : `openssl rand -base64 32`  (ou node -e "console.log(crypto.randomBytes(32).toString('base64'))")
AUTH_SECRET="change-moi-en-secret-aleatoire"
# URL publique du site (en local: http://localhost:3000)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ── Connexion Google (mise en avant) ──
# https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Connexion Microsoft (Entra ID / Azure AD) ──
# https://portal.azure.com → App registrations
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/common/v2.0"

# ── Connexion Apple (nécessite un compte Apple Developer payant) ──
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# ── Compte administrateur ──
# Le compte avec cet email obtient tous les droits admin.
# Il peut se connecter avec email + mot de passe (créé par `npm run db:seed`).
ADMIN_EMAIL="admin@pixeldrop.app"
ADMIN_PASSWORD="change-moi-mot-de-passe-fort"
ADMIN_PSEUDO="Admin"

# ── Stripe (paiements) ──
# https://dashboard.stripe.com/apikeys  (utilise les clés TEST pour commencer)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Secret du webhook (stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET="whsec_..."

# Devise des paiements
NEXT_PUBLIC_CURRENCY="chf"
