// PixelDrop — schéma de base de données
// Prod: PostgreSQL (Neon) via l'adaptateur pg.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
//  Auth.js (NextAuth v5)
// ─────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?

  // Profil de jeu
  pseudo  String  @unique @default(cuid())
  isAdmin Boolean @default(false)
  banned  Boolean @default(false)
  muted   Boolean @default(false)
  bio     String?

  // Économie
  credits       Int     @default(10) // 10 pixels offerts au départ
  freeGranted   Boolean @default(true)
  totalPlaced   Int     @default(0)
  totalSpentCts Int     @default(0) // total dépensé en centimes (EUR)

  // Progression
  xp           Int       @default(0)
  level        Int       @default(1)
  achievements String    @default("") // ids séparés par des virgules
  dailyStreak  Int       @default(0)
  lastDailyAt  DateTime?
  lastSeenAt   DateTime?

  // Personnalisation (équipés — doivent être possédés dans l'inventaire)
  equippedBadge String?
  equippedTitle String?
  nameColor     String?

  // Parrainage
  referralCode String? @unique
  referredById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  Account[]
  sessions  Session[]
  pixels    Pixel[]
  purchases Purchase[]
  items     InventoryItem[]
  chats     ChatMessage[]
  reports   Report[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
//  Jeu
// ─────────────────────────────────────────────

model Pixel {
  id       String  @id @default(cuid())
  x        Int
  y        Int
  color    String // hex "#RRGGBB"
  link     String? // URL optionnelle
  text     String? // message optionnel
  shielded Boolean @default(false)
  golden   Boolean @default(false) // compat historique
  effect   String? // "golden" | "rainbow" | "diamond"

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([x, y])
  @@index([updatedAt])
  @@index([ownerId])
}

model Purchase {
  id              String   @id @default(cuid())
  userId          String
  sku             String
  label           String
  amountCts       Int
  creditsGranted  Int      @default(0)
  itemsGranted    Int      @default(0)
  result          String? // détail du contenu reçu (boîtes mystère, packs)
  stripeSessionId String?  @unique
  status          String   @default("pending") // pending | paid | canceled
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// Inventaire : consommables (bombes…) et déblocages (badges, titres, couleurs)
model InventoryItem {
  id       String @id @default(cuid())
  userId   String
  sku      String
  quantity Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sku])
}

// Chat global
model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  text      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// Signalements de pixels
model Report {
  id         String   @id @default(cuid())
  x          Int
  y          Int
  reason     String
  status     String   @default("open") // open | resolved
  reporterId String?
  createdAt  DateTime @default(now())

  reporter User? @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([status])
}

// Réglages globaux (annonce, version du schéma…)
model Setting {
  key   String @id
  value String
}
