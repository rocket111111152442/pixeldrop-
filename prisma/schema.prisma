// PixelDrop — schéma de base de données
// Prod: PostgreSQL (Neon) via l'adaptateur pg.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
//  Auth.js (NextAuth v5)
// ─────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?

  // Profil de jeu
  pseudo  String  @unique @default(cuid())
  isAdmin Boolean @default(false)
  banned  Boolean @default(false)
  muted   Boolean @default(false)
  bio     String?

  // Modération / sanctions
  bannedAt          DateTime?
  banExpiresAt      DateTime?
  banReason         String?
  banCategory       String?
  banSource         String?
  banSeverity       String?
  banAppealDeadline DateTime?
  banAppealText     String?   @db.Text
  banAppealedAt     DateTime?
  banAppealStatus   String    @default("none") // none | pending | accepted | rejected
  banDeleteAfter    DateTime?

  // Économie
  credits       Int     @default(10) // 10 pixels offerts au départ
  freeGranted   Boolean @default(true)
  totalPlaced   Int     @default(0)
  totalSpentCts Int     @default(0) // total dépensé en centimes (EUR)

  // Progression
  xp           Int       @default(0)
  level        Int       @default(1)
  achievements String    @default("") // ids séparés par des virgules
  dailyStreak  Int       @default(0)
  lastDailyAt  DateTime?
  lastSeenAt   DateTime?

  // Personnalisation (équipés — doivent être possédés dans l'inventaire)
  equippedBadge String?
  equippedTitle String?
  nameColor     String?

  // Parrainage
  referralCode String? @unique
  referredById String?

  // Preuve d'acceptation des conditions générales
  termsAcceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts          Account[]
  sessions          Session[]
  pixels            Pixel[]
  purchases         Purchase[]
  items             InventoryItem[]
  chats             ChatMessage[]
  reports           Report[]
  moderationCases   ModerationCase[] @relation("ModerationSubject")
  moderationActions ModerationCase[] @relation("ModerationAdmin")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
//  Jeu
// ─────────────────────────────────────────────

model Pixel {
  id       String  @id @default(cuid())
  x        Int
  y        Int
  color    String // hex "#RRGGBB"
  link     String? // URL optionnelle
  text     String? // message optionnel
  shielded Boolean @default(false)
  golden   Boolean @default(false) // compat historique
  effect   String? // "golden" | "rainbow" | "diamond"

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([x, y])
  @@index([updatedAt])
  @@index([ownerId])
}

model Purchase {
  id              String   @id @default(cuid())
  userId          String
  sku             String
  label           String
  amountCts       Int
  creditsGranted  Int      @default(0)
  itemsGranted    Int      @default(0)
  result          String? // détail du contenu reçu (boîtes mystère, packs)
  stripeSessionId String?  @unique
  status          String   @default("pending") // pending | paid | canceled
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// Inventaire : consommables (bombes…) et déblocages (badges, titres, couleurs)
model InventoryItem {
  id       String @id @default(cuid())
  userId   String
  sku      String
  quantity Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sku])
}

// Chat global
model ChatMessage {
  id            String    @id @default(cuid())
  userId        String
  text          String
  deletedAt     DateTime?
  deletedReason String?
  deletedById   String?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([deletedAt])
}

// Signalements de pixels
model Report {
  id         String   @id @default(cuid())
  x          Int
  y          Int
  reason     String
  status     String   @default("open") // open | resolved
  reporterId String?
  createdAt  DateTime @default(now())

  reporter User? @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([status])
}

// File de modération créée par le bot, les joueurs ou les admins.
model ModerationCase {
  id         String  @id @default(cuid())
  source     String // bot | user | admin | appeal
  targetType String // pixel | chat | user | appeal
  targetId   String?
  status     String  @default("open") // open | resolved

  userId String?
  user   User?   @relation("ModerationSubject", fields: [userId], references: [id], onDelete: SetNull)

  x    Int?
  y    Int?
  link String? @db.Text
  text String? @db.Text

  category String
  severity String // review | temporary_ban | permanent_ban
  action   String // reported | blocked | message_deleted | banned | account_deleted
  reason   String  @db.Text
  details  String? @db.Text

  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("ModerationAdmin", fields: [resolvedById], references: [id], onDelete: SetNull)
  adminNote    String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([createdAt])
  @@index([targetType, targetId])
}

// Réglages globaux (annonce, version du schéma…)
model Setting {
  key   String @id
  value String
}

// Quêtes collectives : tout le monde y contribue, tout le monde est récompensé.
// Entièrement paramétrable par l'administrateur.
model Quest {
  id          String @id @default(cuid())
  title       String
  description String @default("")
  emoji       String @default("🎯")

  // Objectif : voir GOAL_TYPES dans src/lib/quests.ts
  goalType  String // place | place_color | place_area | bomb | effect
  goalParam String? // couleur "#rrggbb", zone "x,y,w,h", effet "golden"…
  target    Int
  progress  Int     @default(0)

  startAt DateTime @default(now())
  endAt   DateTime

  // Récompense distribuée à TOUS les joueurs si l'objectif est atteint à temps
  rewardCredits Int    @default(0)
  rewardXp      Int    @default(0)
  rewardItems   String @default("") // "bomb:2,shield:1"

  status        String    @default("active") // active | success | failed
  distributedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}
